$date
    Jun 15, 2026  13:28:58
$end
$version
    TOOL:	xmsim	25.03-s001
$end
$timescale
    1 ps
$end

$scope module i2c_tb $end
$var parameter 32 !    address_width $end
$var parameter 32 "    data $end
$var wire      8 #    sda [7:0] $end
$var wire      1 $    scl  $end
$var reg       1 %    clk $end
$var reg       1 &    rst_n $end
$var reg       8 '    address [7:0] $end
$var reg       8 (    sda_drive [7:0] $end
$var reg       1 )    sda_oe $end

$scope module uut $end
$var parameter 32 *    address_width $end
$var parameter 32 +    data $end
$var wire      8 #    sda [7:0] $end
$var reg       1 ,    scl $end
$var wire      1 -    clk  $end
$var wire      1 .    rst_n  $end
$var wire      8 /    address [7:0] $end
$var reg       1 0    data_valid $end
$var reg       1 1    adress_valid $end
$var reg       1 2    stop $end
$var reg       7 3    counter [6:0] $end
$var reg       1 4    read $end
$var reg       1 5    write $end
$var reg       5 6    bit_counter [4:0] $end
$var reg       1 7    adress_state $end
$var reg       1 8    drive_low $end
$var reg       1 9    ack_received $end
$var reg       8 :    data_reg [7:0] $end
$var reg       8 ;    address_reg [7:0] $end
$var reg       2 <    state [1:0] $end
$var reg       1 =    sda_in $end
$var reg       1 >    stop_generated $end
$var reg       1 ?    start_detected $end
$var wire      1 @    start  $end
$var wire      1 A    ack  $end
$upscope $end


$scope task send_byte $end
$var reg       8 B    byte_data [7:0] $end
$var reg       1 C    expect_ack $end
$upscope $end


$scope task receive_byte $end
$var reg       8 D    slave_response [7:0] $end
$upscope $end

$upscope $end

$enddefinitions $end
